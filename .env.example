OPENAI_API_KEY=tu_api_key
OPENAI_MODEL=gpt-5-mini

# Puedes dejar todo configurable desde .env (sin pasar flags)
INPUT_JSON_PATH=example_payload.json
OUTPUT_JSON_PATH=signal.json
ANALYSIS_EVERY_MINUTES=15
REVIEW_EVERY_MINUTES=1
RUN_ONCE=true
DEBUG=false
EXECUTE_REAL_MT5=false

# Opcional: ruta de la base SQLite
SIGNALS_DB_PATH=signals.db

# Opcional: ejecución real en MT5 (solo si usas --execute-real-mt5)
MT5_LOGIN=
MT5_PASSWORD=
MT5_SERVER=
MT5_PATH=
# ejemplo Windows: C:\\Program Files\\MetaTrader 5\\terminal64.exe
MT5_VOLUME=0.01
MT5_MAGIC=20260312
MT5_DEVIATION=20
